class Solution {
    public int countPrimes(int n) {
        
       

       int a[]=new int [n];
        // for(int i=0;i<a.length;i++){
        //     a[i]=1;

        // }
        int count=0;
        for(int i=2;i<n;i++){
            if(a[i]==0){
                count++;
                for(int j=i*2;j<n;j=j+i){
                    a[j]=1;

                }
            
            }
        }
        return count;
        
    }
}
