class Solution {
    public int minMovesToSeat(int[] seats, int[] students) {
        int sum=0;
        Arrays.sort(seats);
        Arrays.sort(students);
        for(int i=0;i<students.length;i++){
           int diff = seats[i]-students[i];
           if(diff<0){
               students[i]= students[i]-diff;
                sum += Math.abs(diff);
           }else{
               students[i]= students[i]+diff;
               sum += Math.abs(diff);
             }

         }
    return sum;
    }
}
